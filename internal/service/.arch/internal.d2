# service package

# Style classes
classes: {
  domain: {
    style.fill: "#e8f4fc"
    style.font-color: "#000"
  }
  service: {
    style.fill: "#f0e8fc"
    style.font-color: "#000"
  }
  factory: {
    style.fill: "#e8fce8"
    style.font-color: "#000"
  }
  value: {
    style.fill: "#f8f8f8"
    style.font-color: "#000"
  }
}

# Legend
legend: {
  label: "Color Legend (DDD)"
  style.stroke: "#999"
  style.fill: "#fafafa"
  near: top-right

  aggregate: {
    label: "Domain Model"
    shape: class
    class: domain
  }
  service: {
    label: "Service"
    shape: class
    class: service
  }
  factory: {
    label: "Factory"
    shape: class
    class: factory
  }
  options: {
    label: "Value Object"
    shape: class
    class: value
  }
}

# Files
compose: {
  label: "compose.go"
  class: value

  expandGlobPatterns: {
    shape: class
    stereotype: "<<function>>"

    "patterns": "[]string"
    "return": "([]string, error)"
  }

  findSpecFiles: {
    shape: class
    stereotype: "<<function>>"

    "paths": "[]string"
    "mode": "internal/service.ComposeMode"
    "return": "([]string, []string, error)"
  }

  hasArchFolder: {
    shape: class
    stereotype: "<<function>>"

    "dir": "string"
    "return": "bool"
  }

  hasGoFiles: {
    shape: class
    stereotype: "<<function>>"

    "dir": "string"
    "return": "bool"
  }


}

factory: {
  label: "factory.go"
  class: value

  NewService: {
    shape: class
    stereotype: "<<factory>>"

    "goReader": "internal/service.ModelReader"
    "d2Reader": "internal/service.ModelReader"
    "d2Writer": "internal/service.ModelWriter"
    "opts": "[]internal/service.Option"
    "return": "*internal/service.Service"
  }

  WithYAML: {
    shape: class
    stereotype: "<<function>>"

    "reader": "internal/service.ModelReader"
    "writer": "internal/service.ModelWriter"
    "return": "internal/service.Option"
  }


  Option: {
    shape: class

    "type": "func(*internal/service.Service)"
  }

}

generate: {
  label: "generate.go"
  class: value

  GenerateOptions: {
    shape: class
    stereotype: "<<struct>>"

    "+Paths []string": ""
    "+PublicOnly bool": ""
    "+InternalOnly bool": ""
    "+FileExtension string": ""
    "+Debug bool": ""
    "+DebugPrintf func(format string, args ...any)": ""
    "+OverlayPath string": ""
    "+GoModPath string": ""
  }

  GenerateResult: {
    shape: class
    stereotype: "<<struct>>"

    "+PackagePath string": ""
    "+PubFile string": ""
    "+InternalFile string": ""
    "+Error error": ""
  }

}

generate_combined: {
  label: "generate_combined.go"
  class: value

  GenerateCombinedOptions: {
    shape: class
    stereotype: "<<struct>>"

    "+Paths []string": ""
    "+OutputPath string": ""
    "+Debug bool": ""
    "+DebugPrintf func(format string, args ...any)": ""
  }

  GenerateCombinedResult: {
    shape: class
    stereotype: "<<struct>>"

    "+OutputPath string": ""
    "+PackageCount int": ""
  }

}

options: {
  label: "options.go"
  class: service

  ModelReader: {
    shape: class
    stereotype: "<<interface>>"

    "+Read(ctx context.Context, paths []string)": "([]internal/domain.PackageModel, error)"
  }

  ModelWriter: {
    shape: class
    stereotype: "<<interface>>"

    "+Write(ctx context.Context, model internal/domain.PackageModel, opts internal/domain.WriteOptions)": "error"
    "+WriteCombined(ctx context.Context, models []internal/domain.PackageModel, outputPath string)": "error"
  }

  ComposeOptions: {
    shape: class
    stereotype: "<<struct>>"

    "+Paths []string": ""
    "+OutputPath string": ""
    "+Mode internal/service.ComposeMode": ""
  }

  ComposeResult: {
    shape: class
    stereotype: "<<struct>>"

    "+OutputPath string": ""
    "+PackageCount int": ""
    "+SkippedPaths []string": ""
  }

  ComposeMode: {
    shape: class
    stereotype: "<<enum>>"

    "type": "int"

    "ComposeModeAuto": "const"
    "ComposeModeSpec": "const"
  }

}

service: {
  label: "service.go"
  class: value

  Service: {
    shape: class
    stereotype: "<<struct>>"

    "-goReader internal/service.ModelReader": ""
    "-d2Reader internal/service.ModelReader": ""
    "-d2Writer internal/service.ModelWriter": ""
    "-yamlReader internal/service.ModelReader": ""
    "-yamlWriter internal/service.ModelWriter": ""

    "+Compose(ctx context.Context, opts internal/service.ComposeOptions)": "(*internal/service.ComposeResult, error)"
    "+Generate(ctx context.Context, opts internal/service.GenerateOptions)": "([]internal/service.GenerateResult, error)"
    "+GenerateWithOverlay(ctx context.Context, opts internal/service.GenerateOptions)": "([]internal/service.GenerateResult, []internal/overlay.Violation, error)"
    "-generateInternal(ctx context.Context, opts internal/service.GenerateOptions)": "([]internal/service.GenerateResult, []internal/overlay.Violation, error)"
    "-generatePackageDiagrams(ctx context.Context, pkg internal/domain.PackageModel, opts internal/service.GenerateOptions)": "internal/service.GenerateResult"
    "-resolveArchDir(pkgPath string)": "string"
    "+GenerateCombined(ctx context.Context, opts internal/service.GenerateCombinedOptions)": "(*internal/service.GenerateCombinedResult, error)"
    "+Split(ctx context.Context, opts internal/service.SplitOptions)": "(*internal/service.SplitResult, error)"
    "-splitPackage(ctx context.Context, pkg internal/domain.PackageModel, dryRun bool)": "internal/service.SplitFileResult"
  }

}

split: {
  label: "split.go"
  class: value

  SplitFileResult: {
    shape: class
    stereotype: "<<struct>>"

    "+PackagePath string": ""
    "+FilePath string": ""
    "+Created bool": ""
    "+Error error": ""
  }

  SplitOptions: {
    shape: class
    stereotype: "<<struct>>"

    "+DiagramPath string": ""
    "+DryRun bool": ""
  }

  SplitResult: {
    shape: class
    stereotype: "<<struct>>"

    "+Files []internal/service.SplitFileResult": ""
    "+DryRun bool": ""
  }

}

# Dependencies
options.ComposeOptions -> options.ComposeMode: "uses"
service.Service -> options.ModelReader: "uses"
service.Service -> options.ModelWriter: "uses"
service.Service -> options.ComposeOptions: "uses"
service.Service -> options.ComposeResult: "returns"
service.Service -> generate.GenerateOptions: "uses"
service.Service -> generate.GenerateResult: "returns"
service.Service -> generate_combined.GenerateCombinedOptions: "uses"
service.Service -> generate_combined.GenerateCombinedResult: "returns"
service.Service -> split.SplitOptions: "uses"
service.Service -> split.SplitResult: "returns"
service.Service -> split.SplitFileResult: "returns"
split.SplitResult -> split.SplitFileResult: "uses"
factory.NewService -> options.ModelReader: "uses"
factory.NewService -> options.ModelWriter: "uses"
factory.NewService -> factory.Option: "uses"
factory.NewService -> service.Service: "returns"
factory.WithYAML -> options.ModelReader: "uses"
factory.WithYAML -> options.ModelWriter: "uses"
factory.WithYAML -> factory.Option: "returns"
compose.findSpecFiles -> options.ComposeMode: "uses"
