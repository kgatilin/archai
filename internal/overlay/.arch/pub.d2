# overlay package

# Style classes
classes: {
  domain: {
    style.fill: "#e8f4fc"
    style.font-color: "#000"
  }
  service: {
    style.fill: "#f0e8fc"
    style.font-color: "#000"
  }
  factory: {
    style.fill: "#e8fce8"
    style.font-color: "#000"
  }
  value: {
    style.fill: "#f8f8f8"
    style.font-color: "#000"
  }
}

# Legend
legend: {
  label: "Color Legend (DDD)"
  style.stroke: "#999"
  style.fill: "#fafafa"
  near: top-right

  aggregate: {
    label: "Domain Model"
    shape: class
    class: domain
  }
  service: {
    label: "Service"
    shape: class
    class: service
  }
  factory: {
    label: "Factory"
    shape: class
    class: factory
  }
  options: {
    label: "Value Object"
    shape: class
    class: value
  }
}

# Files
config: {
  label: "config.go"
  class: value

  Aggregate: {
    shape: class
    stereotype: "<<struct>>"

    "+Root string": ""
  }

  Config: {
    shape: class
    stereotype: "<<struct>>"

    "+Module string": ""
    "+Layers map[string][]string": ""
    "+LayerRules map[string][]string": ""
    "+Aggregates map[string]internal/overlay.Aggregate": ""
    "+Configs []string": ""
  }

}

load: {
  label: "load.go"
  class: value

  Load: {
    shape: class
    stereotype: "<<function>>"

    "path": "string"
    "return": "(*internal/overlay.Config, error)"
  }

  LoadComposed: {
    shape: class
    stereotype: "<<function>>"

    "path": "string"
    "return": "(*internal/overlay.Config, error)"
  }


}

merge: {
  label: "merge.go"
  class: value

  Violation: {
    shape: class
    stereotype: "<<struct>>"

    "+Package string": ""
    "+Layer string": ""
    "+Imports []string": ""
  }

  Merge: {
    shape: class
    stereotype: "<<function>>"

    "models": "[]internal/domain.PackageModel"
    "cfg": "*internal/overlay.Config"
    "return": "([]internal/domain.PackageModel, []internal/overlay.Violation, error)"
  }


}

validate: {
  label: "validate.go"
  class: value

  Validate: {
    shape: class
    stereotype: "<<function>>"

    "cfg": "*internal/overlay.Config"
    "goModPath": "string"
    "return": "error"
  }


}

# Dependencies
load.Load -> config.Config: "returns"
load.LoadComposed -> config.Config: "returns"
merge.Merge -> config.Config: "uses"
merge.Merge -> merge.Violation: "returns"
validate.Validate -> config.Config: "uses"
