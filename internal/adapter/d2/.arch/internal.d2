# d2 package

# Legend
legend: {
  label: "Color Legend (DDD)"
  style.stroke: "#999"
  style.fill: "#fafafa"
  near: top-right

  aggregate: {
    label: "Domain Model"
    shape: class
    style.fill: "#e8f4fc"
    style.font-color: "#000"
  }
  service: {
    label: "Service"
    shape: class
    style.fill: "#f0e8fc"
    style.font-color: "#000"
  }
  factory: {
    label: "Factory"
    shape: class
    style.fill: "#e8fce8"
    style.font-color: "#000"
  }
  options: {
    label: "Value Object"
    shape: class
    style.fill: "#f8f8f8"
    style.font-color: "#000"
  }
}

# Files
builder: {
  label: "builder.go"
  style.fill: "#f8f8f8"

  d2TextBuilder: {
    shape: class
    stereotype: "<<struct>>"

    "-buf strings.Builder": ""
    "-indent int": ""

    "+Build(pkg internal/domain.PackageModel, publicOnly bool)": "string"
    "-groupByFile(pkg internal/domain.PackageModel, publicOnly bool)": "[]internal/adapter/d2.fileGroup"
    "-writeFileContainer(fg internal/adapter/d2.fileGroup, publicOnly bool)": ""
    "-collectSymbolInfo(fg internal/adapter/d2.fileGroup)": "[]internal/adapter/d2.symbolInfo"
    "-fileContainerID(filename string)": "string"
    "-writeInterface(iface internal/domain.InterfaceDef, publicOnly bool)": ""
    "-writeStruct(s internal/domain.StructDef, publicOnly bool)": ""
    "-writeFunctions(functions []internal/domain.FunctionDef, publicOnly bool)": ""
    "-writeFunctionAsClass(fn internal/domain.FunctionDef)": ""
    "-writeTypeDef(td internal/domain.TypeDef)": ""
    "-writeMethod(m internal/domain.MethodDef)": ""
    "-writeField(f internal/domain.FieldDef)": ""
    "-formatMethodSignature(m internal/domain.MethodDef)": "string"
    "-formatParams(params []internal/domain.ParamDef)": "string"
    "-formatReturns(returns []internal/domain.TypeRef)": "string"
    "-filterDependencies(deps []internal/domain.Dependency, publicOnly bool, pkg internal/domain.PackageModel)": "[]internal/domain.Dependency"
    "-writeDependency(dep internal/domain.Dependency)": ""
    "-toD2Path(ref internal/domain.SymbolRef)": "string"
    "-writeComment(text string)": ""
    "-writeLine(line string)": ""
    "-writeRaw(text string)": ""
  }

  fileGroup: {
    shape: class
    stereotype: "<<struct>>"

    "-filename string": ""
    "-interfaces []internal/domain.InterfaceDef": ""
    "-structs []internal/domain.StructDef": ""
    "-functions []internal/domain.FunctionDef": ""
    "-typeDefs []internal/domain.TypeDef": ""
  }

  newD2TextBuilder: {
    shape: class
    stereotype: "<<function>>"

    "return": "*internal/adapter/d2.d2TextBuilder"
  }


}

combined_builder: {
  label: "combined_builder.go"
  style.fill: "#f8f8f8"

  combinedBuilder: {
    shape: class
    stereotype: "<<struct>>"

    "-buf strings.Builder": ""
    "-indent int": ""

    "+Build(packages []internal/domain.PackageModel)": "string"
    "-writePackageContainer(pkg internal/domain.PackageModel, symbolIndex map[string]map[string]bool)": ""
    "-collectSymbolInfo(pkg internal/domain.PackageModel)": "[]internal/adapter/d2.symbolInfo"
    "-writeInterface(iface internal/domain.InterfaceDef)": ""
    "-writeStruct(s internal/domain.StructDef)": ""
    "-writeFunction(fn internal/domain.FunctionDef)": ""
    "-writeTypeDef(td internal/domain.TypeDef)": ""
    "-writeMethod(m internal/domain.MethodDef)": ""
    "-writeField(f internal/domain.FieldDef)": ""
    "-formatMethodSignature(m internal/domain.MethodDef)": "string"
    "-formatParams(params []internal/domain.ParamDef)": "string"
    "-formatReturns(returns []internal/domain.TypeRef)": "string"
    "-filterExportedMethods(methods []internal/domain.MethodDef)": "[]internal/domain.MethodDef"
    "-filterExportedFields(fields []internal/domain.FieldDef)": "[]internal/domain.FieldDef"
    "-buildSymbolIndex(packages []internal/domain.PackageModel)": "map[string]map[string]bool"
    "-collectIntraPackageDeps(pkg internal/domain.PackageModel, symbolIndex map[string]map[string]bool)": "[]internal/adapter/d2.depInfo"
    "-collectCrossPackageDeps(packages []internal/domain.PackageModel, symbolIndex map[string]map[string]bool)": "[]internal/adapter/d2.depInfo"
    "-writeIntraPackageDep(dep internal/adapter/d2.depInfo)": ""
    "-writeCrossPackageDep(dep internal/adapter/d2.depInfo)": ""
    "-writeComment(text string)": ""
    "-writeLine(line string)": ""
    "-writeRaw(text string)": ""
  }

  depInfo: {
    shape: class
    stereotype: "<<struct>>"

    "-fromPkg string": ""
    "-fromSymbol string": ""
    "-toPkg string": ""
    "-toSymbol string": ""
    "-kind internal/domain.DependencyKind": ""
  }

  newCombinedBuilder: {
    shape: class
    stereotype: "<<function>>"

    "return": "*internal/adapter/d2.combinedBuilder"
  }

  sanitizePackageID: {
    shape: class
    stereotype: "<<function>>"

    "path": "string"
    "return": "string"
  }


}

reader: {
  label: "reader.go"
  style.fill: "#f8f8f8"

  reader: {
    shape: class
    stereotype: "<<struct>>"

    "+Read(ctx context.Context, paths []string)": "([]internal/domain.PackageModel, error)"
    "-readFile(path string)": "([]internal/domain.PackageModel, error)"
    "-parseAST(ast *oss.terrastruct.com/d2/d2ast.Map)": "([]internal/domain.PackageModel, error)"
    "-parsePackageContainer(m *oss.terrastruct.com/d2/d2ast.Map)": "(internal/domain.PackageModel, error)"
    "-parseSymbol(name string, m *oss.terrastruct.com/d2/d2ast.Map)": "(any, internal/adapter/d2.symbolKind)"
    "-parseInterface(name string, m *oss.terrastruct.com/d2/d2ast.Map)": "internal/domain.InterfaceDef"
    "-parseStruct(name string, m *oss.terrastruct.com/d2/d2ast.Map)": "internal/domain.StructDef"
    "-parseFunction(name string, m *oss.terrastruct.com/d2/d2ast.Map, stereotype string)": "internal/domain.FunctionDef"
    "-parseTypeDef(name string, m *oss.terrastruct.com/d2/d2ast.Map, stereotype internal/domain.Stereotype)": "internal/domain.TypeDef"
    "-parseMethod(signature string, returnStr string)": "internal/domain.MethodDef"
    "-parseField(fieldStr string)": "internal/domain.FieldDef"
  }

  NewReader: {
    shape: class
    stereotype: "<<factory>>"

    "return": "internal/service.ModelReader"
  }

  getKeyPathString: {
    shape: class
    stereotype: "<<function>>"

    "kp": "*oss.terrastruct.com/d2/d2ast.KeyPath"
    "return": "string"
  }

  getScalarValue: {
    shape: class
    stereotype: "<<function>>"

    "vb": "oss.terrastruct.com/d2/d2ast.ValueBox"
    "return": "string"
  }

  isExported: {
    shape: class
    stereotype: "<<function>>"

    "name": "string"
    "return": "bool"
  }

  parseParams: {
    shape: class
    stereotype: "<<function>>"

    "paramStr": "string"
    "return": "[]internal/domain.ParamDef"
  }

  parseReturnTypes: {
    shape: class
    stereotype: "<<function>>"

    "returnStr": "string"
    "return": "[]internal/domain.TypeRef"
  }

  parseTypeRef: {
    shape: class
    stereotype: "<<function>>"

    "typeStr": "string"
    "return": "internal/domain.TypeRef"
  }

  splitParams: {
    shape: class
    stereotype: "<<function>>"

    "s": "string"
    "return": "[]string"
  }


  symbolKind: {
    shape: class
    stereotype: "<<enum>>"

    "type": "int"

    "symbolKindFunction": "const"
    "symbolKindInterface": "const"
    "symbolKindStruct": "const"
    "symbolKindTypeDef": "const"
    "symbolKindUnknown": "const"
  }

}

styles: {
  label: "styles.go"
  style.fill: "#f8f8f8"

  symbolInfo: {
    shape: class
    stereotype: "<<struct>>"

    "-stereotype internal/domain.Stereotype": ""
  }

  fileContainerColor: {
    shape: class
    stereotype: "<<function>>"

    "symbols": "[]internal/adapter/d2.symbolInfo"
    "return": "string"
  }

  stereotypeColor: {
    shape: class
    stereotype: "<<function>>"

    "s": "internal/domain.Stereotype"
    "return": "string"
  }

  stereotypeLabel: {
    shape: class
    stereotype: "<<function>>"

    "s": "internal/domain.Stereotype"
    "return": "string"
  }


}

templates: {
  label: "templates.go"
  style.fill: "#f8f8f8"

  legendTemplate: {
    shape: class
    stereotype: "<<function>>"

    "return": "string"
  }


}

writer: {
  label: "writer.go"
  style.fill: "#f8f8f8"

  writer: {
    shape: class
    stereotype: "<<struct>>"

    "+Write(ctx context.Context, model internal/domain.PackageModel, opts internal/domain.WriteOptions)": "error"
    "+WriteCombined(ctx context.Context, models []internal/domain.PackageModel, outputPath string)": "error"
  }

  NewWriter: {
    shape: class
    stereotype: "<<factory>>"

    "return": "internal/service.ModelWriter"
  }


}

# Dependencies
combined_builder.combinedBuilder -> styles.symbolInfo: "returns"
combined_builder.combinedBuilder -> combined_builder.depInfo: "returns"
builder.d2TextBuilder -> builder.fileGroup: "returns"
builder.d2TextBuilder -> styles.symbolInfo: "returns"
reader.reader -> reader.symbolKind: "returns"
styles.fileContainerColor -> styles.symbolInfo: "uses"
combined_builder.newCombinedBuilder -> combined_builder.combinedBuilder: "returns"
builder.newD2TextBuilder -> builder.d2TextBuilder: "returns"
