convert.toCallEdgeSpec -> schema.CallEdgeSpec: "returns"
convert.toConstSpec -> schema.ConstSpec: "returns"
convert.toDependencySpec -> schema.DependencySpec: "returns"
convert.toErrorSpec -> schema.ErrorSpec: "returns"
convert.toFieldSpec -> schema.FieldSpec: "returns"
