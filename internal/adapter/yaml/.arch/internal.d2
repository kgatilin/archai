convert.fromErrorSpec -> schema.ErrorSpec: "uses"
convert.fromFieldSpec -> schema.FieldSpec: "uses"
convert.fromFunctionSpec -> schema.FunctionSpec: "uses"
convert.fromImplementationSpec -> schema.ImplementationSpec: "uses"
convert.fromInterfaceSpec -> schema.InterfaceSpec: "uses"
convert.fromMethodSpec -> schema.MethodSpec: "uses"
convert.fromParamSpec -> schema.ParamSpec: "uses"
convert.fromSpec -> schema.PackageSpec: "uses"
