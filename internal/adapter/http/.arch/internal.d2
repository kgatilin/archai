  targetsPageData: {
    shape: class
    stereotype: "<<struct>>"

    "-pageData internal/adapter/http.pageData": ""
    "+ActiveTarget string": ""
    "+HasActive bool": ""
    "+Targets []internal/target.TargetMeta": ""
    "+Error string": ""
  }

  buildGroups: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "filter": "string"
    "return": "[]internal/adapter/http.diffGroup"
  }

  buildKindFilters: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "selected": "string"
    "return": "[]internal/adapter/http.kindFilter"
  }

  findProjectYAMLSpecs: {
    shape: class
    stereotype: "<<function>>"

    "root": "string"
    "return": "([]string, error)"
  }

  formatSide: {
    shape: class
    stereotype: "<<function>>"

    "v": "any"
    "return": "string"
  }

  hasYAMLExt: {
    shape: class
    stereotype: "<<function>>"

    "p": "string"
    "return": "bool"
  }

  isHTMX: {
    shape: class
    stereotype: "<<function>>"

    "r": "*net/http.Request"
    "return": "bool"
  }

  loadCurrentFromDisk: {
    shape: class
    stereotype: "<<function>>"

    "ctx": "context.Context"
    "root": "string"
    "return": "([]internal/domain.PackageModel, error)"
  }

  loadDiffSides: {
    shape: class
    stereotype: "<<function>>"

    "ctx": "context.Context"
    "root": "string"
    "targetID": "string"
    "return": "([]internal/domain.PackageModel, []internal/domain.PackageModel, error)"
  }

  loadTargetFromDisk: {
    shape: class
    stereotype: "<<function>>"

    "ctx": "context.Context"
    "root": "string"
    "id": "string"
    "return": "([]internal/domain.PackageModel, error)"
  }

  summarize: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "return": "internal/adapter/http.diffSummary"
  }

  walkYAML: {
    shape: class
    stereotype: "<<function>>"

    "root": "string"
    "return": "([]string, error)"
  }


  Variables: {
    shape: class
    stereotype: "<<var>>"

    "kindOrder": "[]struct{...}"
    "opOrder": "[]struct{...}"
  }

}

