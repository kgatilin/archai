# http package

# Style classes
classes: {
  domain: {
    style.fill: "#e8f4fc"
    style.font-color: "#000"
  }
  service: {
    style.fill: "#f0e8fc"
    style.font-color: "#000"
  }
  factory: {
    style.fill: "#e8fce8"
    style.font-color: "#000"
  }
  value: {
    style.fill: "#f8f8f8"
    style.font-color: "#000"
  }
}

# Legend
legend: {
  label: "Color Legend (DDD)"
  style.stroke: "#999"
  style.fill: "#fafafa"
  near: top-right

  aggregate: {
    label: "Domain Model"
    shape: class
    class: domain
  }
  service: {
    label: "Service"
    shape: class
    class: service
  }
  factory: {
    label: "Factory"
    shape: class
    class: factory
  }
  options: {
    label: "Value Object"
    shape: class
    class: value
  }
}

# Files
api: {
  label: "api.go"
  class: value

  firstTextContent: {
    shape: class
    stereotype: "<<function>>"

    "res": "internal/adapter/mcp.ToolResult"
    "return": "string"
  }

  readJSONBody: {
    shape: class
    stereotype: "<<function>>"

    "r": "*net/http.Request"
    "return": "(encoding/json.RawMessage, error)"
  }

  trimBOM: {
    shape: class
    stereotype: "<<function>>"

    "b": "[]byte"
    "return": "[]byte"
  }

  writeAPIToolResult: {
    shape: class
    stereotype: "<<function>>"

    "w": "net/http.ResponseWriter"
    "res": "internal/adapter/mcp.ToolResult"
    "rpcErr": "*internal/adapter/mcp.RPCError"
  }

  writeJSONError: {
    shape: class
    stereotype: "<<function>>"

    "w": "net/http.ResponseWriter"
    "code": "int"
    "msg": "string"
  }

  writeJSONErrorText: {
    shape: class
    stereotype: "<<function>>"

    "w": "net/http.ResponseWriter"
    "status": "int"
    "msg": "string"
  }


}

configs: {
  label: "configs.go"
  class: value

  configField: {
    shape: class
    stereotype: "<<struct>>"

    "+Name string": ""
    "+Type string": ""
    "+Tag string": ""
    "+IsExported bool": ""
    "+Default string": ""
  }

  configPageData: {
    shape: class
    stereotype: "<<struct>>"

    "-pageData internal/adapter/http.pageData": ""
    "+HasOverlay bool": ""
    "+Module string": ""
    "+Configs []internal/adapter/http.configView": ""
    "+Missing []string": ""
  }

  configView: {
    shape: class
    stereotype: "<<struct>>"

    "+Package string": ""
    "+Name string": ""
    "+TypeHref string": ""
    "+Doc string": ""
    "+Fields []internal/adapter/http.configField": ""
    "+Example string": ""
    "+FromSource string": ""
  }

  buildConfigFields: {
    shape: class
    stereotype: "<<function>>"

    "fields": "[]internal/domain.FieldDef"
    "return": "[]internal/adapter/http.configField"
  }

  buildFQN: {
    shape: class
    stereotype: "<<function>>"

    "module": "string"
    "pkgPath": "string"
    "name": "string"
    "return": "string"
  }

  collectConfigs: {
    shape: class
    stereotype: "<<function>>"

    "packages": "[]internal/domain.PackageModel"
    "cfg": "*internal/overlay.Config"
    "return": "([]internal/adapter/http.configView, []string)"
  }

  defaultLiteral: {
    shape: class
    stereotype: "<<function>>"

    "t": "internal/domain.TypeRef"
    "return": "string"
  }

  synthesizeExample: {
    shape: class
    stereotype: "<<function>>"

    "s": "internal/domain.StructDef"
    "return": "string"
  }


}

dashboard: {
  label: "dashboard.go"
  class: value

  dashboardData: {
    shape: class
    stereotype: "<<struct>>"

    "-pageData internal/adapter/http.pageData": ""
    "+Module string": ""
    "+GoVersion string": ""
    "+CurrentTarget string": ""
    "+HasTarget bool": ""
    "+DriftStatus string": ""
    "+DriftCount int": ""
    "+DriftMessage string": ""
    "+PackageCount int": ""
    "+TypeCount int": ""
    "+FunctionCount int": ""
    "+InterfaceCount int": ""
    "+HasLayerMap bool": ""
  }

  collectTargetYAMLFiles: {
    shape: class
    stereotype: "<<function>>"

    "root": "string"
    "return": "([]string, error)"
  }

  computeDrift: {
    shape: class
    stereotype: "<<function>>"

    "ctx": "context.Context"
    "root": "string"
    "targetID": "string"
    "current": "[]internal/domain.PackageModel"
    "return": "(string, int, string)"
  }

  readGoModInfo: {
    shape: class
    stereotype: "<<function>>"

    "path": "string"
    "return": "(string, string, bool)"
  }


}

diff_targets: {
