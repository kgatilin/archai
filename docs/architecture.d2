    "return": "(internal/domain.SymbolRef, bool)"
  }

  # Dependencies
  Build -> Node: "returns"
  FormatD2 -> Node: "uses"
  FormatText -> Node: "uses"

}

internal.serve: {
  label: "internal/serve"
  class: value

  ActivityAware: {
    shape: class
    stereotype: "<<interface>>"

    "+SetActivityObserver(func())": ""
  }

  HTTPTransport: {
    shape: class
    stereotype: "<<interface>>"

