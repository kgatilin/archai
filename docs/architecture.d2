  Service: {
    shape: class
    stereotype: "<<struct>>"

    "+Compose(ctx context.Context, opts internal/service.ComposeOptions)": "(*internal/service.ComposeResult, error)"
    "+Generate(ctx context.Context, opts internal/service.GenerateOptions)": "([]internal/service.GenerateResult, error)"
    "+GenerateWithOverlay(ctx context.Context, opts internal/service.GenerateOptions)": "([]internal/service.GenerateResult, []internal/overlay.Violation, error)"
    "+GenerateCombined(ctx context.Context, opts internal/service.GenerateCombinedOptions)": "(*internal/service.GenerateCombinedResult, error)"
    "+Split(ctx context.Context, opts internal/service.SplitOptions)": "(*internal/service.SplitResult, error)"
