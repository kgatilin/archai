# Combined Architecture Diagram

# Style classes
classes: {
  domain: {
    style.fill: "#e8f4fc"
    style.font-color: "#000"
  }
  service: {
    style.fill: "#f0e8fc"
    style.font-color: "#000"
  }
  factory: {
    style.fill: "#e8fce8"
    style.font-color: "#000"
  }
  value: {
    style.fill: "#f8f8f8"
    style.font-color: "#000"
  }
}

# Legend
legend: {
  label: "Color Legend (DDD)"
  style.stroke: "#999"
  style.fill: "#fafafa"
  near: top-right

  aggregate: {
    label: "Domain Model"
    shape: class
    class: domain
  }
  service: {
    label: "Service"
    shape: class
    class: service
  }
  factory: {
    label: "Factory"
    shape: class
    class: factory
  }
  options: {
    label: "Value Object"
    shape: class
    class: value
  }
}

# Packages
cmd.archai: {
  label: "cmd/archai"
  class: value

  Variables: {
    shape: class
    stereotype: "<<var>>"

    "Version": "string"
  }

}

internal.adapter.d2: {
  label: "internal/adapter/d2"
  class: factory

  NewReader: {
    shape: class
    stereotype: "<<factory>>"

    "return": "internal/service.ModelReader"
  }

  NewWriter: {
    shape: class
    stereotype: "<<factory>>"

    "return": "internal/service.ModelWriter"
  }

  Constants: {
    shape: class
    stereotype: "<<const>>"

    "ClassDomain": "untyped string = \"domain\""
    "ClassFactory": "untyped string = \"factory\""
    "ClassService": "untyped string = \"service\""
    "ClassValue": "untyped string = \"value\""
    "ColorBlue": "untyped string = \"#e8f4fc\""
    "ColorGray": "untyped string = \"#f8f8f8\""
    "ColorGreen": "untyped string = \"#e8fce8\""
    "ColorLegendBorder": "untyped string = \"#999\""
    "ColorLegendFill": "untyped string = \"#fafafa\""
    "ColorPurple": "untyped string = \"#f0e8fc\""
  }

  Errors: {
    shape: class
    stereotype: "<<error>>"

    "ErrEmptyDiagram": "D2 file is empty or contains no meaningful content"
    "ErrInvalidLabel": "package container has invalid or missing label"
    "ErrNoPackages": "no package containers found in D2 file"
  }

}

internal.adapter.golang: {
  label: "internal/adapter/golang"
  class: factory

  NewReader: {
    shape: class
    stereotype: "<<factory>>"

    "return": "internal/service.ModelReader"
  }

}

internal.adapter.http: {
  label: "internal/adapter/http"
  class: factory

  Server: {
    shape: class
    stereotype: "<<struct>>"

    "+SetActivityObserver(fn func())": ""
    "+Serve(ctx context.Context, addr string, ready func(boundAddr string))": "error"
  }

  NewMultiServer: {
    shape: class
    stereotype: "<<factory>>"

    "multi": "*internal/serve.MultiState"
    "return": "(*internal/adapter/http.Server, error)"
  }

  NewServer: {
    shape: class
    stereotype: "<<factory>>"

    "state": "*internal/serve.State"
    "return": "(*internal/adapter/http.Server, error)"
  }

  # Dependencies
  NewMultiServer -> Server: "returns"
  NewServer -> Server: "returns"

}

internal.adapter.mcp: {
  label: "internal/adapter/mcp"
  class: value

  ClientOptions: {
    shape: class
    stereotype: "<<struct>>"

    "+Endpoint string": ""
    "+HTTPClient *net/http.Client": ""
  }

  PackageSummary: {
    shape: class
    stereotype: "<<struct>>"

    "+Path string": ""
    "+Name string": ""
    "+Layer string": ""
    "+InterfaceCount int": ""
    "+StructCount int": ""
    "+FunctionCount int": ""
  }

  RPCError: {
    shape: class
    stereotype: "<<struct>>"

    "+Code int": ""
    "+Message string": ""
    "+Data any": ""
  }

  Request: {
    shape: class
    stereotype: "<<struct>>"

    "+JSONRPC string": ""
    "+ID encoding/json.RawMessage": ""
    "+Method string": ""
    "+Params encoding/json.RawMessage": ""
  }

  Response: {
    shape: class
    stereotype: "<<struct>>"

    "+JSONRPC string": ""
    "+ID encoding/json.RawMessage": ""
    "+Result interface{}": ""
    "+Error *internal/adapter/mcp.RPCError": ""
  }

  ToolDefinition: {
    shape: class
    stereotype: "<<struct>>"

    "+Name string": ""
    "+Description string": ""
    "+InputSchema any": ""
  }

  ToolResult: {
    shape: class
    stereotype: "<<struct>>"

    "+Content []internal/adapter/mcp.ToolResultContent": ""
    "+IsError bool": ""
  }

  ToolResultContent: {
    shape: class
    stereotype: "<<struct>>"

    "+Type string": ""
    "+Text string": ""
  }

  ValidateResult: {
    shape: class
    stereotype: "<<struct>>"

    "+OK bool": ""
    "+Target string": ""
    "+Violations []internal/diff.Change": ""
  }

  Dispatch: {
    shape: class
    stereotype: "<<function>>"

    "state": "*internal/serve.State"
    "name": "string"
    "rawArgs": "encoding/json.RawMessage"
    "return": "(internal/adapter/mcp.ToolResult, *internal/adapter/mcp.RPCError)"
  }

  Serve: {
    shape: class
    stereotype: "<<function>>"

    "ctx": "context.Context"
    "state": "*internal/serve.State"
    "return": "error"
  }

  ServeClient: {
    shape: class
    stereotype: "<<function>>"

    "ctx": "context.Context"
    "opts": "internal/adapter/mcp.ClientOptions"
    "return": "error"
  }

  ToolDefinitions: {
    shape: class
    stereotype: "<<function>>"

    "return": "[]internal/adapter/mcp.ToolDefinition"
  }

  Constants: {
    shape: class
    stereotype: "<<const>>"

    "ErrInternal": "untyped int = -32603"
    "ErrInvalidParams": "untyped int = -32602"
    "ErrInvalidRequest": "untyped int = -32600"
    "ErrMethodNotFound": "untyped int = -32601"
    "ErrParseError": "untyped int = -32700"
  }

  # Dependencies
  Dispatch -> RPCError: "returns"
  Dispatch -> ToolResult: "returns"
  Response -> RPCError: "uses"
  ServeClient -> ClientOptions: "uses"
  ToolDefinitions -> ToolDefinition: "returns"
  ToolResult -> ToolResultContent: "uses"

}

