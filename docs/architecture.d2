internal.apply: {
  label: "internal/apply"
  class: value

  Apply: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "currentModels": "[]internal/domain.PackageModel"
    "targetModels": "[]internal/domain.PackageModel"
    "return": "([]internal/domain.PackageModel, error)"
  }

}

internal.diff: {
  label: "internal/diff"
  class: value

  Change: {
    shape: class
    stereotype: "<<struct>>"

    "+Op internal/diff.Op": ""
    "+Kind internal/diff.Kind": ""
    "+Path string": ""
    "+Before any": ""
    "+After any": ""
  }

  Diff: {
    shape: class
    stereotype: "<<struct>>"

    "+Changes []internal/diff.Change": ""

    "+IsEmpty()": "bool"
  }

  Compute: {
    shape: class
    stereotype: "<<function>>"

    "current": "[]internal/domain.PackageModel"
    "target": "[]internal/domain.PackageModel"
    "return": "*internal/diff.Diff"
  }

  FormatJSON: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "return": "(string, error)"
  }

  FormatText: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "return": "string"
  }

  FormatYAML: {
    shape: class
    stereotype: "<<function>>"

    "d": "*internal/diff.Diff"
    "return": "(string, error)"
  }

  Kind: {
    shape: class
    stereotype: "<<enum>>"

    "type": "string"

    "KindConst": "const"
    "KindDep": "const"
    "KindError": "const"
    "KindField": "const"
    "KindFunction": "const"
    "KindInterface": "const"
    "KindLayerRule": "const"
    "KindMethod": "const"
    "KindPackage": "const"
    "KindStruct": "const"
    "KindTypeDef": "const"
    "KindVar": "const"
  }

  Op: {
    shape: class
    stereotype: "<<enum>>"

    "type": "string"

    "OpAdd": "const"
    "OpChange": "const"
    "OpRemove": "const"
  }

  # Dependencies
  Change -> Kind: "uses"
  Change -> Op: "uses"
  Compute -> Diff: "returns"
  Diff -> Change: "uses"
  FormatJSON -> Diff: "uses"
  FormatText -> Diff: "uses"
  FormatYAML -> Diff: "uses"

}

