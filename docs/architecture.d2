internal.overlay: {
  label: "internal/overlay"
  class: value

  Aggregate: {
    shape: class
    stereotype: "<<struct>>"

    "+Root string": ""
  }

  Config: {
    shape: class
    stereotype: "<<struct>>"

    "+Module string": ""
    "+Layers map[string][]string": ""
    "+LayerRules map[string][]string": ""
    "+Aggregates map[string]internal/overlay.Aggregate": ""
    "+Configs []string": ""
  }

  Violation: {
    shape: class
    stereotype: "<<struct>>"

    "+Package string": ""
    "+Layer string": ""
    "+Imports []string": ""
  }

  Load: {
    shape: class
    stereotype: "<<function>>"

    "path": "string"
    "return": "(*internal/overlay.Config, error)"
  }

  LoadComposed: {
    shape: class
    stereotype: "<<function>>"

    "path": "string"
    "return": "(*internal/overlay.Config, error)"
  }

  Merge: {
    shape: class
    stereotype: "<<function>>"

    "models": "[]internal/domain.PackageModel"
    "cfg": "*internal/overlay.Config"
    "return": "([]internal/domain.PackageModel, []internal/overlay.Violation, error)"
  }

  Validate: {
    shape: class
    stereotype: "<<function>>"

    "cfg": "*internal/overlay.Config"
    "goModPath": "string"
    "return": "error"
  }

  # Dependencies
  Load -> Config: "returns"
  LoadComposed -> Config: "returns"
  Merge -> Config: "uses"
  Merge -> Violation: "returns"
  Validate -> Config: "uses"

}

internal.sequence: {
  label: "internal/sequence"
  class: value

  Node: {
    shape: class
    stereotype: "<<struct>>"

    "+Symbol internal/domain.SymbolRef": ""
    "+Via string": ""
