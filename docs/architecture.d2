    "+Cycle bool": ""
    "+DepthLimit bool": ""
    "+NotFound bool": ""
  }

  Build: {
    shape: class
    stereotype: "<<function>>"

    "models": "[]internal/domain.PackageModel"
    "start": "internal/domain.SymbolRef"
    "maxDepth": "int"
    "return": "*internal/sequence.Node"
  }

  FormatD2: {
    shape: class
    stereotype: "<<function>>"

    "root": "*internal/sequence.Node"
    "return": "string"
  }

  FormatText: {
    shape: class
    stereotype: "<<function>>"

    "root": "*internal/sequence.Node"
    "return": "string"
  }

  ParseTarget: {
    shape: class
    stereotype: "<<function>>"

